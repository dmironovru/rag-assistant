FROM golang:1.23-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -o rag-assistant .

FROM alpine:latest
RUN apk --no-cache add ca-certificates postgresql-client

WORKDIR /root/
COPY --from=builder /app/rag-assistant .

EXPOSE 8081

CMD ["./rag-assistant"]
