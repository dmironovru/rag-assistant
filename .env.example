# ==========================================
# .env.example — Шаблон переменных окружения
# Скопируй в .env: cp .env.example .env
# ==========================================

# === PostgreSQL ===
POSTGRES_USER=rag
POSTGRES_PASSWORD=ChangeMeToStrongPass123!  # ️ Обязательно измени
POSTGRES_DB=rag_docs

# === Backend (Go RAG API) ===
# Модель для векторного поиска (эмбеддинги)
EMBED_MODEL=nomic-embed-text

# === Frontend (Next.js) ===
NODE_ENV=development

# Внутренний URL Go API (для Docker)
RAG_API_URL=http://backend:8080/api/search

# URL Ollama для генерации ответов
OLLAMA_URL=http://ollama:11434/api/generate

# Модель для генерации текста (ответы ассистента)
LLM_MODEL=mistral:7b

# === Опционально: GitHub Token ===
# Раскомментируй и вставь токен, если при индексации упрёшься в лимит 60 запросов/час
# GITHUB_TOKEN=ghp_ваш_токен_здесь
